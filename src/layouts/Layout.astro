---
import "../styles/global.css";
import Navbar from "@components/Navbar.astro";
import Footer from "@components/Footer.astro";
import WhatsAppButton from "@components/WhatsAppButton.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Nutrióloga Yanely García | Tu aliada para una vida más saludable",
  description = "Consultas de nutrición presenciales en Ocotlán de Morelos y Santa Lucía del Camino, Oaxaca, y en línea para todo el mundo. Amor, cariño y respeto a la nutrición."
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <title>{title}</title>
  </head>
  <body class="flex min-h-screen flex-col font-body">
    <Navbar />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <WhatsAppButton />
  </body>
</html>
