---
import "../styles/global.css";
import Navbar from "@components/layout/Navbar.astro";
import Footer from "@components/layout/Footer.astro";
import WhatsAppButton from "@components/layout/WhatsAppButton.astro";
import StructuredData from "@components/layout/StructuredData.astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = "Nutrióloga Yanely García | Tu aliada para una vida más saludable",
  description = "Yanely García: nutrióloga en Ocotlán de Morelos, Oaxaca, y en línea para todo el mundo. Planes contra resistencia a la insulina, diabetes y SOP.",
  image = "/nutri.webp",
} = Astro.props;

// Texto e imagen que se muestran en las tarjetas de vista previa al compartir el enlace
// (WhatsApp, Facebook, etc.) — distinto del meta description, que se enfoca en SEO local.
const shareDescription =
  "Planes de alimentación que se adaptan a ti, a tus hábitos, tus gustos y tu economía — no al revés.";
const shareImage = new URL(image, Astro.site);
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <!-- Debe coincidir con --color-cream en global.css; el atributo content no admite var(). -->
    <meta name="theme-color" content="#fbf3e7" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="canonical" href={Astro.url} />

    <title>{title}</title>

    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:site_name" content="Nutrióloga Yanely García" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={shareDescription} />
    <meta property="og:image" content={shareImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={shareDescription} />
    <meta name="twitter:image" content={shareImage} />

    <StructuredData />
  </head>
  <body class="font-body flex min-h-screen flex-col">
    <Navbar />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <WhatsAppButton />
  </body>
</html>
