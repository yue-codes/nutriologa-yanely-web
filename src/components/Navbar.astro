---
/**
 * Navbar con menú móvil hecho con el "checkbox hack" (sin JavaScript):
 * el checkbox #nav-toggle controla, vía CSS (peer-checked), si el panel
 * de enlaces móvil se muestra. Si se necesita lógica más compleja en el
 * futuro, esto se puede migrar a un componente Preact con estado.
 */
import Logo from "@components/Logo.astro";
import Button from "@components/Button.astro";
import MenuIcon from "@icons/MenuIcon.astro";
import { linkWhatsApp } from "@data/contacto";

const enlaces = [
  { href: "/", texto: "Inicio" },
  { href: "/sobre-mi", texto: "Sobre mí" },
  { href: "/servicios", texto: "Servicios" },
  { href: "/blog", texto: "Blog" },
  { href: "/contacto", texto: "Contacto" }
];
---

<header class="sticky top-0 z-40 bg-cream/95 backdrop-blur">
  <input type="checkbox" id="nav-toggle" class="peer hidden" />

  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-2">
    <Logo class="scale-[0.85]" />

    <nav class="hidden items-center gap-6 md:flex">
      {
        enlaces.map((enlace) => (
          <a href={enlace.href} class="font-body font-semibold text-ink hover:text-primary">
            {enlace.texto}
          </a>
        ))
      }
      <Button href={linkWhatsApp()} variant="love" target="_blank">Agenda tu cita</Button>
    </nav>

    <label for="nav-toggle" class="cursor-pointer p-2 md:hidden" aria-label="Abrir menú de navegación">
      <MenuIcon class="h-7 w-7 text-ink" />
    </label>
  </div>

  <nav class="hidden flex-col gap-4 border-t border-ink/10 bg-cream px-4 py-4 peer-checked:flex md:hidden">
    {
      enlaces.map((enlace) => (
        <a href={enlace.href} class="font-body font-semibold text-ink hover:text-primary">
          {enlace.texto}
        </a>
      ))
    }
    <Button href={linkWhatsApp()} variant="love" target="_blank" class="w-fit">
      Agenda tu cita
    </Button>
  </nav>
</header>
