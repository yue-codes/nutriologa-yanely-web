---
import type { CollectionEntry } from "astro:content";

interface Props {
  entry: CollectionEntry<"blog">;
}
const { entry } = Astro.props;
const { titulo, resumen, fecha, categoria, imagen, imagenAlt } = entry.data;

const fechaFormateada = fecha.toLocaleDateString("es-MX", {
  day: "numeric",
  month: "long",
  year: "numeric"
});
---

<a
  href={`/blog/${entry.id}`}
  class="group flex flex-col overflow-hidden rounded-3xl bg-white/70 shadow-sm ring-1 ring-ink/5 transition-shadow hover:shadow-md"
>
  <img
    src={imagen}
    alt={imagenAlt}
    width="800"
    height="500"
    loading="lazy"
    class="h-48 w-full object-cover"
  />
  <div class="flex flex-1 flex-col p-6">
    <span class="font-body text-xs font-bold tracking-wide text-accent uppercase">{categoria}</span>
    <h3 class="mt-2 font-heading text-lg font-semibold text-ink group-hover:text-primary">
      {titulo}
    </h3>
    <p class="mt-2 flex-1 font-body text-sm text-ink/80">{resumen}</p>
    <time datetime={fecha.toISOString()} class="mt-4 font-body text-xs text-ink/60">
      {fechaFormateada}
    </time>
  </div>
</a>
