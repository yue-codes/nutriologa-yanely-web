---
import type { Testimonio } from "@data/testimonios";

interface Props {
  testimonio: Testimonio;
}
const { testimonio } = Astro.props;
---

<figure
  class="ring-ink/5 flex h-full flex-col rounded-3xl bg-white/70 p-6 shadow-sm ring-1"
>
  <blockquote class="font-body text-ink/90">
    “{testimonio.comentario}”
  </blockquote>
  <figcaption class="mt-4 flex items-center gap-3">
    <img
      src={testimonio.avatar}
      alt={`Foto de ${testimonio.nombre}`}
      width="44"
      height="44"
      loading="lazy"
      class="h-11 w-11 rounded-full object-cover"
    />
    <span class="font-body text-ink font-semibold">{testimonio.nombre}</span>
  </figcaption>
</figure>
