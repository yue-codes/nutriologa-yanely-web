---
import type { Testimonio } from "@data/testimonios";
import GoogleIcon from "@icons/GoogleIcon.astro";
import FacebookIcon from "@icons/FacebookIcon.astro";

interface Props {
  testimonio: Testimonio;
}
const { testimonio } = Astro.props;
const inicial = testimonio.nombre.charAt(0).toUpperCase();
---

<figure
  class="flex w-full flex-shrink-0 flex-col items-center px-2 text-center"
>
  {
    /*
      rounded-[56px], no rounded-full: combining Tailwind v4's rounded-full
      (border-radius: calc(infinity*1px)) with ring-4 renders a flat-topped
      circle in Chromium once this wrapper has an absolutely-positioned
      sibling (the badge below) — a fixed radius avoids the bug entirely.
    */
  }
  <div class="relative h-28 w-28">
    {
      testimonio.avatar ? (
        <img
          src={testimonio.avatar}
          alt={`Foto de ${testimonio.nombre}`}
          width="112"
          height="112"
          loading="lazy"
          class="ring-secondary/50 h-28 w-28 rounded-[56px] object-cover shadow-md ring-4"
        />
      ) : (
        <div
          class="ring-secondary/50 bg-secondary/15 text-secondary font-heading flex h-28 w-28 items-center justify-center rounded-[56px] text-4xl font-semibold shadow-md ring-4"
          aria-hidden="true"
        >
          {inicial}
        </div>
      )
    }
    <span
      class="ring-ink/5 absolute right-0 bottom-0 flex h-8 w-8 items-center justify-center rounded-full bg-white shadow-sm ring-1"
      title={testimonio.fuente === "google"
        ? "Reseña de Google"
        : "Reseña de Facebook"}
    >
      {
        testimonio.fuente === "google" ? (
          <GoogleIcon class="size-4" />
        ) : (
          <FacebookIcon class="text-secondary size-4" />
        )
      }
    </span>
  </div>
  <figcaption class="font-heading text-ink mt-5 text-xl font-semibold">
    {testimonio.nombre}
  </figcaption>
  <blockquote
    class="font-body text-ink/70 mx-auto mt-4 max-w-md text-lg italic"
  >
    “{testimonio.comentario}”
  </blockquote>
</figure>
