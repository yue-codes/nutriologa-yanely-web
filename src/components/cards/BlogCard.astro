---
import type { CollectionEntry } from "astro:content";

interface Props {
  entry: CollectionEntry<"blog">;
}
const { entry } = Astro.props;
const { titulo, fecha, categoria, imagen, imagenAlt } = entry.data;

const fechaFormateada = fecha.toLocaleDateString("es-MX", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
---

<a
  href={`/blog/${entry.id}`}
  class="group relative isolate flex aspect-[4/5] flex-col justify-end overflow-hidden rounded-3xl"
>
  <img
    src={imagen}
    alt={imagenAlt}
    width="800"
    height="1000"
    loading="lazy"
    class="absolute inset-0 -z-20 h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
  />
  <div
    class="from-ink/90 via-ink/30 absolute inset-0 -z-10 bg-gradient-to-t to-transparent"
    aria-hidden="true"
  >
  </div>
  <div class="p-6">
    <span
      class="font-body text-secondary text-xs font-bold tracking-wide uppercase"
    >
      {categoria}
    </span>
    <h2 class="font-heading text-cream mt-2 text-lg font-semibold">
      {titulo}
    </h2>
    <time
      datetime={fecha.toISOString()}
      class="font-body text-cream/70 mt-2 block text-xs"
    >
      {fechaFormateada}
    </time>
  </div>
</a>
