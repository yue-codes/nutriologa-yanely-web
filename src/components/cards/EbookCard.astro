---
import type { Libro } from "@data/libros";

interface Props {
  libro: Libro;
}
const { libro } = Astro.props;
---

<a
  href={`/blog/${libro.blogSlug}`}
  class="group relative isolate flex aspect-[4/5] flex-col justify-end overflow-hidden rounded-3xl"
>
  <img
    src={libro.imagen}
    alt={libro.imagenAlt}
    width="800"
    height="1000"
    loading="lazy"
    class="absolute inset-0 -z-20 h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
  />
  <div
    class="from-ink/90 via-ink/40 absolute inset-0 -z-10 bg-gradient-to-t to-transparent"
    aria-hidden="true"
  >
  </div>
  <span
    class="font-heading bg-love text-cream absolute top-4 right-4 z-10 rounded-full px-3 py-1 text-sm font-bold shadow-md"
  >
    {libro.precio}
  </span>
  <div class="p-6">
    <h3 class="font-heading text-cream text-lg font-semibold">
      {libro.titulo}
    </h3>
    <p class="font-body text-cream/80 mt-2 text-sm">{libro.resumen}</p>
    <span
      class="font-body text-cream/70 mt-3 inline-block text-xs font-bold tracking-wide uppercase"
    >
      Ver más →
    </span>
  </div>
</a>
