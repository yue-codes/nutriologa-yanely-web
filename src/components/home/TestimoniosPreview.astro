---
import Section from "@components/ui/Section.astro";
import TestimonialCard from "@components/cards/TestimonialCard.astro";
import TestimoniosCarousel from "@components/home/TestimoniosCarousel.tsx";
import MaizIcon from "@icons/MaizIcon.astro";
import { testimonios } from "@data/testimonios";
---

<Section eyebrow="Testimonios" titulo="Lo que dicen de mí" centrado>
  <div class="mt-5 flex items-center justify-center gap-3">
    <span class="bg-accent/40 h-px w-8"></span>
    <MaizIcon class="text-accent size-5" />
    <span class="bg-accent/40 h-px w-8"></span>
  </div>

  <div class="mx-auto mt-10 max-w-xl md:max-w-2xl">
    <TestimoniosCarousel client:visible total={testimonios.length}>
      {
        testimonios.map((testimonio) => (
          <TestimonialCard testimonio={testimonio} />
        ))
      }
    </TestimoniosCarousel>
  </div>
</Section>
