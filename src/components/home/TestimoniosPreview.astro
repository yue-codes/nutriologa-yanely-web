---
import Section from "@components/ui/Section.astro";
import TestimonialCard from "@components/cards/TestimonialCard.astro";
import TestimoniosCarousel from "@components/home/TestimoniosCarousel.tsx";
import { testimonios } from "@data/testimonios";

const acentos = ["love", "primary", "secondary", "accent"] as const;
---

<Section eyebrow="Reviews" titulo="Lo que dicen de mí" centrado>
  <div class="mx-auto mt-10 max-w-2xl md:max-w-5xl">
    <TestimoniosCarousel client:visible total={testimonios.length}>
      {
        testimonios.map((testimonio, i) => (
          <div class="w-[85%] flex-shrink-0 px-2 md:w-[28%]">
            <TestimonialCard
              testimonio={testimonio}
              accent={acentos[i % acentos.length]}
            />
          </div>
        ))
      }
    </TestimoniosCarousel>
  </div>
</Section>
