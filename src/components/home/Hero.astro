---
import Button from "@components/ui/Button.astro";
import QuoteBlock from "@components/ui/QuoteBlock.astro";
import { linkWhatsApp } from "@data/contacto";
---

<section
  class="flex min-h-[calc(100dvh-4rem)] items-center overflow-hidden px-4 py-10"
>
  <div class="mx-auto grid max-w-6xl items-center gap-10 md:grid-cols-2">
    <div>
      <p
        class="font-body text-accent text-sm font-bold tracking-wide uppercase"
      >
        Consultas presenciales en Oaxaca y en línea para todo el mundo
      </p>
      <h1 class="font-heading text-ink mt-3 text-4xl font-semibold md:text-5xl">
        Tu aliada para una vida más saludable
      </h1>
      <QuoteBlock class="mt-6"
        >Amor, cariño y respeto a la nutrición.</QuoteBlock
      >
      <p class="font-body text-ink/80 mt-4">
        Planes de alimentación que se adaptan a ti, a tus hábitos y a tu
        economía — no al revés.
      </p>
      <div class="mt-8 flex flex-wrap gap-4">
        <Button href={linkWhatsApp()} variant="love" target="_blank"
          >Agenda tu cita</Button
        >
        <Button href="/servicios" variant="outline">Conoce mis servicios</Button
        >
      </div>
    </div>

    <div class="relative mx-auto max-w-sm">
      <div
        class="bg-secondary/40 absolute inset-0 -z-10 translate-x-4 translate-y-4 rounded-[3rem]"
        aria-hidden="true"
      >
      </div>
      <img
        src="/nutri.webp"
        alt="Yanely García, nutrióloga, sonriendo"
        width="480"
        height="480"
        class="relative w-full rounded-[3rem] object-contain"
      />
    </div>
  </div>
</section>
