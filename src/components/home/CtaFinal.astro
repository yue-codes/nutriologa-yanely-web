---
import Section from "@components/ui/Section.astro";
import Button from "@components/ui/Button.astro";
import { linkWhatsApp } from "@data/contacto";
---

<Section class="text-center">
  <img
    src="/avatarnutri/nutry8.png"
    alt=""
    class="mx-auto h-40 w-auto"
    aria-hidden="true"
  />
  <h2
    class="font-heading text-ink mx-auto max-w-2xl text-3xl font-semibold md:text-4xl"
  >
    ¿Lista para empezar tu cambio de hábitos?
  </h2>
  <div class="mt-6">
    <Button href={linkWhatsApp()} variant="love" target="_blank"
      >Agenda tu cita por WhatsApp</Button
    >
  </div>
</Section>
