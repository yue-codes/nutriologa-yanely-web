---
import Section from "@components/ui/Section.astro";
import EbookCard from "@components/cards/EbookCard.astro";
import { libros } from "@data/libros";
---

<Section eyebrow="Aprende a tu ritmo" titulo="Mis Ebooks" centrado>
  <div
    class="no-scrollbar mt-10 flex snap-x snap-mandatory gap-5 overflow-x-auto pb-2"
  >
    {
      libros.map((libro) => (
        <div class="w-60 shrink-0 snap-start sm:w-64 md:w-72">
          <EbookCard libro={libro} />
        </div>
      ))
    }
  </div>

  <div class="mt-6 text-center">
    <a
      href="/ebooks"
      class="font-body text-primary font-semibold hover:underline"
    >
      Ver todos mis ebooks →
    </a>
  </div>
</Section>
