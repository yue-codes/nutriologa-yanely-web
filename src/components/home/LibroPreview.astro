---
import Section from "@components/ui/Section.astro";
import Button from "@components/ui/Button.astro";
import MaizIcon from "@icons/MaizIcon.astro";
import { libros } from "@data/libros";

const libro = libros[0];
---

<Section>
  <div class="mx-auto grid max-w-5xl items-center gap-14 md:grid-cols-2">
    <div class="relative mx-auto w-72 md:w-[28rem]">
      <div
        class="bg-secondary/30 absolute inset-0 -z-10 scale-105 rounded-[45%_55%_60%_40%/55%_45%_60%_40%]"
        aria-hidden="true"
      >
      </div>
      <img
        src={libro.imagen}
        alt={libro.imagenAlt}
        width="360"
        height="460"
        loading="lazy"
        class="relative w-full object-contain"
      />
    </div>

    <div class="text-center md:text-left">
      <span
        class="font-body text-accent text-xs font-bold tracking-wide uppercase"
      >
        Por {libro.autor}
      </span>
      <h2 class="font-heading text-ink mt-2 text-3xl font-bold md:text-4xl">
        Presento mi libro:<br />
        “{libro.titulo}”
      </h2>

      <div
        class="mt-5 flex items-center justify-center gap-3 md:justify-start"
      >
        <span class="bg-accent/40 h-px w-8"></span>
        <MaizIcon class="text-accent size-5" />
        <span class="bg-accent/40 h-px w-8"></span>
      </div>

      <p class="font-body text-ink mt-5 font-semibold">{libro.resumen}</p>
      <p class="font-body text-ink/70 mt-3">{libro.descripcion}</p>

      <div class="mt-7 flex justify-center md:justify-start">
        <Button href={`/blog/${libro.blogSlug}`} variant="accent"
          >Más información</Button
        >
      </div>
    </div>
  </div>
</Section>
