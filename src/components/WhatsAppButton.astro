---
/** Botón flotante de WhatsApp, visible en todas las páginas (montado desde Layout.astro). */
import WhatsAppIcon from "@icons/WhatsAppIcon.astro";
import { linkWhatsApp } from "@data/contacto";
---

<a
  href={linkWhatsApp()}
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Escribir por WhatsApp"
  class="fixed bottom-5 right-5 z-50 flex h-14 w-14 items-center justify-center rounded-full bg-primary text-cream shadow-lg transition-transform hover:scale-105"
>
  <WhatsAppIcon class="h-7 w-7" />
</a>
