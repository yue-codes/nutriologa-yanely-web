---
/** Encabezado de página simple, usado en Sobre mí, Servicios, Blog y Contacto. */
interface Props {
  eyebrow?: string;
  titulo: string;
  descripcion?: string;
}
const { eyebrow, titulo, descripcion } = Astro.props;
---

<header class="bg-secondary/20 px-4 py-16 text-center">
  {eyebrow && <p class="font-body text-sm font-bold tracking-wide text-accent uppercase">{eyebrow}</p>}
  <h1 class="mt-2 font-heading text-4xl font-semibold text-ink md:text-5xl">{titulo}</h1>
  {descripcion && <p class="mx-auto mt-4 max-w-2xl font-body text-ink/80">{descripcion}</p>}
</header>
