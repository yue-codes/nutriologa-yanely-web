---
import Logo from "@components/Logo.astro";
import InstagramIcon from "@icons/InstagramIcon.astro";
import FacebookIcon from "@icons/FacebookIcon.astro";
import WhatsAppIcon from "@icons/WhatsAppIcon.astro";
import MapPinIcon from "@icons/MapPinIcon.astro";
import { contacto, linkWhatsApp } from "@data/contacto";

const anio = new Date().getFullYear();
---

<footer class="mt-16 bg-ink text-cream">
  <div class="mx-auto grid max-w-6xl gap-10 px-4 py-12 md:grid-cols-3">
    <div>
      <Logo class="scale-110" dark />
      <p class="mt-4 font-body text-sm text-cream/80">
        LN. Ed. Yanely García · Nutrióloga<br />
        Céd. Profesional: 11856808
      </p>
    </div>

    <div>
      <h3 class="font-heading text-lg font-semibold">Ubicaciones</h3>
      <ul class="mt-3 space-y-2 font-body text-sm text-cream/80">
        {
          contacto.ubicaciones.map((u) => (
            <li class="flex items-start gap-2">
              <MapPinIcon class="mt-0.5 h-4 w-4 shrink-0 text-secondary" />
              <span>{u.lugar} — {u.modalidad}</span>
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <h3 class="font-heading text-lg font-semibold">Síguenos</h3>
      <div class="mt-3 flex gap-4">
        <a href={linkWhatsApp()} target="_blank" rel="noopener noreferrer" aria-label="WhatsApp" class="hover:text-secondary">
          <WhatsAppIcon class="h-6 w-6" />
        </a>
        <a href={contacto.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="hover:text-secondary">
          <InstagramIcon class="h-6 w-6" />
        </a>
        <a href={contacto.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="hover:text-secondary">
          <FacebookIcon class="h-6 w-6" />
        </a>
      </div>
    </div>
  </div>

  <p class="border-t border-cream/10 px-4 py-4 text-center font-body text-xs text-cream/60">
    © {anio} Nutrióloga Yanely García. Todos los derechos reservados.
  </p>
</footer>
