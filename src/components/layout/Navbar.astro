---
/**
 * Navbar con menú móvil hecho con el "checkbox hack" (sin JavaScript):
 * el checkbox #nav-toggle controla, vía CSS (peer-checked), si el panel
 * de enlaces móvil se muestra. Si se necesita lógica más compleja en el
 * futuro, esto se puede migrar a un componente Preact con estado.
 */
import Logo from "@components/layout/Logo.astro";
import Button from "@components/ui/Button.astro";
import MenuIcon from "@icons/MenuIcon.astro";
import { linkWhatsApp } from "@data/contacto";

const enlaces = [
  { href: "/", texto: "Inicio" },
  { href: "/sobre-mi", texto: "Sobre mí" },
  { href: "/servicios", texto: "Servicios" },
  { href: "/blog", texto: "Blog" },
  { href: "/contacto", texto: "Contacto" },
];
---

<header class="bg-cream/95 sticky top-0 z-40 backdrop-blur">
  <input type="checkbox" id="nav-toggle" class="peer hidden" />

  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-4">
    <Logo class="scale-[0.85]" />

    <nav class="hidden items-center gap-6 md:flex">
      {
        enlaces.map((enlace) => (
          <a
            href={enlace.href}
            class="font-body text-ink hover:text-primary font-semibold"
          >
            {enlace.texto}
          </a>
        ))
      }
      <Button href={linkWhatsApp()} variant="love" target="_blank"
        >Agenda tu cita</Button
      >
    </nav>

    <label
      for="nav-toggle"
      class="cursor-pointer p-2 md:hidden"
      aria-label="Abrir menú de navegación"
    >
      <MenuIcon class="text-ink h-7 w-7" />
    </label>
  </div>

  <nav
    class="border-ink/10 bg-cream hidden flex-col gap-4 border-t px-4 py-4 peer-checked:flex md:hidden"
  >
    {
      enlaces.map((enlace) => (
        <a
          href={enlace.href}
          class="font-body text-ink hover:text-primary font-semibold"
        >
          {enlace.texto}
        </a>
      ))
    }
    <Button href={linkWhatsApp()} variant="love" target="_blank" class="w-fit">
      Agenda tu cita
    </Button>
  </nav>
</header>
