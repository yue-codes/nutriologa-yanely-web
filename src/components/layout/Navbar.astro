---
import Logo from "@components/layout/Logo.astro";
import Button from "@components/ui/Button.astro";
import MobileNav from "@components/layout/MobileNav.tsx";
import { linkWhatsApp } from "@data/contacto";

const enlaces = [
  { href: "/", texto: "Inicio" },
  { href: "/sobre-mi", texto: "Sobre mí" },
  { href: "/servicios", texto: "Servicios" },
  { href: "/blog", texto: "Blog" },
  { href: "/contacto", texto: "Contacto" },
];
---

<header class="sticky top-0 z-40 px-4 pt-4">
  <div
    class="ring-ink/5 mx-auto flex h-16 max-w-6xl items-center justify-between rounded-full bg-white/40 px-4 ring-1 backdrop-blur-xl backdrop-saturate-150 sm:px-6"
  >
    <Logo class="scale-[0.85]" />

    <nav class="hidden items-center gap-6 md:flex">
      {
        enlaces.map((enlace) => (
          <a
            href={enlace.href}
            class="font-body text-ink hover:text-primary font-semibold"
          >
            {enlace.texto}
          </a>
        ))
      }
      <Button href={linkWhatsApp()} variant="love" target="_blank"
        >Agenda tu cita</Button
      >
    </nav>

    <MobileNav
      client:load
      enlaces={enlaces}
      whatsappHref={linkWhatsApp()}
      currentPath={Astro.url.pathname}
    />
  </div>
</header>
