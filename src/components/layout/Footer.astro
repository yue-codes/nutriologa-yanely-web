---
import Logo from "@components/layout/Logo.astro";
import InstagramIcon from "@icons/InstagramIcon.astro";
import FacebookIcon from "@icons/FacebookIcon.astro";
import TikTokIcon from "@icons/TikTokIcon.astro";
import WhatsAppIcon from "@icons/WhatsAppIcon.astro";
import MapPinIcon from "@icons/MapPinIcon.astro";
import Credits from "@components/layout/Credits.astro";
import { contacto, linkWhatsApp } from "@data/contacto";
---

<footer class="bg-ink text-cream mt-16">
  <div class="mx-auto grid max-w-6xl gap-10 px-4 py-12 md:grid-cols-3">
    <div>
      <Logo class="scale-110" dark />
      <p class="font-body text-cream/80 mt-4 text-sm">
        LN. Ed. Yanely García · Nutrióloga<br />
        Céd. Profesional: 11856808
      </p>
    </div>

    <div>
      <h3 class="font-heading text-lg font-semibold">Ubicaciones</h3>
      <ul class="font-body text-cream/80 mt-3 space-y-2 text-sm">
        {
          contacto.ubicaciones.map((u) => (
            <li class="flex items-start gap-2">
              <MapPinIcon class="text-secondary mt-0.5 h-4 w-4 shrink-0" />
              <span>
                {u.lugar} — {u.modalidad}
              </span>
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <h3 class="font-heading text-lg font-semibold">Síguenos</h3>
      <div class="mt-3 flex gap-4">
        <a
          href={linkWhatsApp()}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="WhatsApp"
          class="hover:text-secondary"
        >
          <WhatsAppIcon class="h-6 w-6" />
        </a>
        <a
          href={contacto.instagram}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Instagram"
          class="hover:text-secondary"
        >
          <InstagramIcon class="h-6 w-6" />
        </a>
        <a
          href={contacto.facebook}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Facebook"
          class="hover:text-secondary"
        >
          <FacebookIcon class="h-6 w-6" />
        </a>
        <a
          href={contacto.tiktok}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="TikTok"
          class="hover:text-secondary"
        >
          <TikTokIcon class="h-6 w-6" />
        </a>
      </div>
    </div>
  </div>

  <Credits owner="Nutrióloga Yanely García" />
</footer>
