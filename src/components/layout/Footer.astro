---
import Logo from "@components/layout/Logo.astro";
import InstagramIcon from "@icons/InstagramIcon.astro";
import FacebookIcon from "@icons/FacebookIcon.astro";
import TikTokIcon from "@icons/TikTokIcon.astro";
import WhatsAppIcon from "@icons/WhatsAppIcon.astro";
import MapPinIcon from "@icons/MapPinIcon.astro";
import Credits from "@components/layout/Credits.astro";
import { contacto, linkWhatsApp } from "@data/contacto";

// Mismo patrón de badges de color por red que ya usan contacto.astro y
// links.astro, para que el Footer se sienta parte del mismo sistema visual.
const redes = [
  {
    href: linkWhatsApp(),
    label: "WhatsApp",
    Icono: WhatsAppIcon,
    badge: "bg-love/15 text-love",
  },
  {
    href: contacto.instagram,
    label: "Instagram",
    Icono: InstagramIcon,
    badge: "bg-accent/15 text-accent",
  },
  {
    href: contacto.facebook,
    label: "Facebook",
    Icono: FacebookIcon,
    badge: "bg-secondary/15 text-secondary",
  },
  {
    href: contacto.tiktok,
    label: "TikTok",
    Icono: TikTokIcon,
    badge: "bg-cream/15 text-cream",
  },
] as const;

// Presenciales van a su ubicación real (liga de Maps si ya se tiene, o una
// búsqueda de Maps a partir del mismo mapsQuery aproximado que usa el mapa
// embebido de /contacto); "En línea" no tiene dirección, así que manda a
// WhatsApp con un mensaje que ya deja claro que es una consulta en línea.
const mapaHref = (u: (typeof contacto.ubicaciones)[number]) => {
  if (u.mapsUrl) return u.mapsUrl;
  if (u.mapsQuery)
    return `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(u.mapsQuery)}`;
  return linkWhatsApp("Quiero agendar una consulta en línea");
};
---

<footer class="bg-ink text-cream mt-16">
  <div class="from-primary via-accent to-love h-1 bg-gradient-to-r"></div>

  <div class="mx-auto grid max-w-6xl gap-10 px-4 py-14 md:grid-cols-3">
    <div>
      <Logo class="scale-110" dark />
      <p class="font-body text-cream/70 mt-4 text-sm">
        LN. Ed. Yanely García · Nutrióloga<br />
        Céd. Profesional: 11856808
      </p>
    </div>

    <div>
      <h3
        class="font-body text-cream/50 text-xs font-bold tracking-wide uppercase"
      >
        Ubicaciones
      </h3>
      <ul class="mt-4 space-y-3">
        {
          contacto.ubicaciones.map((u) => (
            <li>
              <a
                href={mapaHref(u)}
                target="_blank"
                rel="noopener noreferrer"
                class="group flex items-center gap-3"
              >
                <span class="bg-secondary/15 text-secondary flex h-8 w-8 shrink-0 items-center justify-center rounded-full transition group-hover:-translate-y-0.5">
                  <MapPinIcon class="h-4 w-4" />
                </span>
                <span class="flex flex-col">
                  <span class="font-body text-cream group-hover:text-secondary text-sm font-semibold transition">
                    {u.lugar}
                  </span>
                  <span class="font-body text-cream/50 text-[0.7rem] font-bold tracking-wide uppercase">
                    {u.modalidad}
                  </span>
                </span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <h3
        class="font-body text-cream/50 text-xs font-bold tracking-wide uppercase"
      >
        Síguenos
      </h3>
      <div class="mt-4 flex gap-3">
        {
          redes.map(({ href, label, Icono, badge }) => (
            <a
              href={href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={label}
              class:list={[
                "flex h-10 w-10 items-center justify-center rounded-full transition hover:-translate-y-0.5",
                badge,
              ]}
            >
              <Icono class="h-5 w-5" />
            </a>
          ))
        }
      </div>
      <a
        href="/links"
        class="font-body text-cream/60 hover:text-secondary mt-5 inline-flex items-center gap-1 text-xs font-semibold"
      >
        Todos mis enlaces →
      </a>
    </div>
  </div>

  <Credits owner="Nutrióloga Yanely García" />
</footer>
