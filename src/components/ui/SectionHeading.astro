---
/**
 * Encabezado de sección reutilizable: texto pequeño ("eyebrow") + título grande.
 * Mantiene la tipografía de títulos (Fraunces) consistente en todo el sitio.
 */
interface Props {
  eyebrow?: string;
  titulo: string;
  centrado?: boolean;
  class?: string;
}

const { eyebrow, titulo, centrado = false, class: className } = Astro.props;
---

<div class:list={["max-w-2xl", centrado && "mx-auto text-center", className]}>
  {
    eyebrow && (
      <p class="font-body text-accent mb-2 text-sm font-bold tracking-wide uppercase">
        {eyebrow}
      </p>
    )
  }
  <h2 class="font-heading text-ink text-3xl font-semibold md:text-4xl">
    {titulo}
  </h2>
</div>
