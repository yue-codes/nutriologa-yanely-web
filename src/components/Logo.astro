---
/**
 * Logo de marca PROVISIONAL: reproduce la composición del logo real
 * (4 íconos + nombre en cursiva + "Nutrióloga") con los íconos propios de
 * src/icons/. Reemplázalo por <img> con el logo en alta calidad cuando
 * Yanely lo entregue — el resto de los componentes no necesita cambiar,
 * solo este archivo.
 */
import CerebroIcon from "@icons/CerebroIcon.astro";
import MaizIcon from "@icons/MaizIcon.astro";
import HojaIcon from "@icons/HojaIcon.astro";
import CorazonIcon from "@icons/CorazonIcon.astro";

interface Props {
  class?: string;
  /** Activa en fondos oscuros (ej. el Footer) para que el subtítulo sea legible. */
  dark?: boolean;
}
const { class: className, dark = false } = Astro.props;
---

<a href="/" class:list={["inline-flex flex-col items-center leading-none", className]}>
  <span class="flex items-center gap-1">
    <CerebroIcon class="h-4 w-4 text-secondary" />
    <MaizIcon class="h-4 w-4 text-accent" />
    <HojaIcon class="h-4 w-4 text-primary" />
    <CorazonIcon class="h-4 w-4 text-love" />
  </span>
  <span class="font-accent text-2xl text-love">Yanely García</span>
  <span class:list={["-mt-1 font-body text-[0.6rem] font-bold tracking-widest uppercase", dark ? "text-cream/70" : "text-ink/60"]}>
    Nutrióloga
  </span>
</a>
