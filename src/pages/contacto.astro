---
import Layout from "@layouts/Layout.astro";
import PageHeader from "@components/ui/PageHeader.astro";
import Section from "@components/ui/Section.astro";
import Button from "@components/ui/Button.astro";
import QuoteBlock from "@components/ui/QuoteBlock.astro";
import MapEmbed from "@components/ui/MapEmbed.astro";
import WhatsAppIcon from "@icons/WhatsAppIcon.astro";
import MailIcon from "@icons/MailIcon.astro";
import InstagramIcon from "@icons/InstagramIcon.astro";
import FacebookIcon from "@icons/FacebookIcon.astro";
import TikTokIcon from "@icons/TikTokIcon.astro";
import MapPinIcon from "@icons/MapPinIcon.astro";
import HojaIcon from "@icons/HojaIcon.astro";
import MaizIcon from "@icons/MaizIcon.astro";
import CerebroIcon from "@icons/CerebroIcon.astro";
import CorazonIcon from "@icons/CorazonIcon.astro";
import { contacto, linkWhatsApp } from "@data/contacto";
import { testimonios } from "@data/testimonios";

// Colores de marca literales (no interpolados) para que Tailwind los detecte,
// mismo patrón que el mapa de íconos de ServiceCategoryCard.astro.
const metodos = [
  {
    href: contacto.instagram,
    label: "Instagram",
    nombre: "Instagram",
    Icono: InstagramIcon,
    badge: "bg-accent/10 text-accent",
  },
  {
    href: contacto.facebook,
    label: "Facebook",
    nombre: "Facebook",
    Icono: FacebookIcon,
    badge: "bg-secondary/10 text-secondary",
  },
  {
    href: contacto.tiktok,
    label: "TikTok",
    nombre: "TikTok",
    Icono: TikTokIcon,
    badge: "bg-ink/10 text-ink",
  },
  {
    href: `mailto:${contacto.email}`,
    label: contacto.email,
    nombre: "Correo",
    Icono: MailIcon,
    badge: "bg-primary/10 text-primary",
  },
] as const;

// Las ubicaciones con mapa se muestran como tarjetas de consultorio; la que
// no tiene dirección (consultas en línea) se muestra aparte, como banner.
const presenciales = contacto.ubicaciones.filter((u) => u.mapsQuery);
const enLinea = contacto.ubicaciones.find((u) => !u.mapsQuery);

// Un par de testimonios como respaldo justo antes de que decidan escribir.
const testimoniosDestacados = testimonios.slice(0, 2);
---

<Layout
  title="Contacto | Nutrióloga Yanely García"
  description="Agenda tu consulta por WhatsApp, o escríbeme por Instagram, Facebook y TikTok."
>
  <PageHeader
    eyebrow="Hablemos"
    titulo="Contacto"
    descripcion="La forma más rápida de agendar tu cita es por WhatsApp."
    imagenFondo="/sobremihero.jpg"
    imagenFondoAlt="Yanely García chocando la palma con una paciente, sonriendo"
  />

  <Section class="relative overflow-hidden">
    <HojaIcon
      class="text-primary pointer-events-none absolute -top-8 -right-8 -z-10 size-40 rotate-12 opacity-[0.07] md:size-52"
    />
    <MaizIcon
      class="text-accent pointer-events-none absolute -bottom-10 -left-10 -z-10 size-40 -rotate-12 opacity-[0.07] md:size-52"
    />

    <div class="mx-auto max-w-xl text-center">
      <QuoteBlock>Escríbeme, con gusto te respondo.</QuoteBlock>
      <div class="mt-6">
        <Button href={linkWhatsApp()} variant="love" target="_blank">
          <WhatsAppIcon class="h-5 w-5" /> Escríbeme por WhatsApp
        </Button>
      </div>
    </div>

    <div class="mx-auto mt-12 flex max-w-3xl flex-wrap justify-center gap-8">
      {
        metodos.map(({ href, label, nombre, Icono, badge }) => (
          <a
            href={href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={label}
            class="group flex flex-col items-center gap-2"
          >
            <span
              class:list={[
                "ring-ink/5 flex h-16 w-16 items-center justify-center rounded-full shadow-sm ring-1 transition group-hover:-translate-y-0.5 group-hover:shadow-md",
                badge,
              ]}
            >
              <Icono class="h-7 w-7" />
            </span>
            <span class="font-body text-ink/70 text-xs font-semibold">
              {nombre}
            </span>
          </a>
        ))
      }
    </div>

    <div class="mx-auto mt-12 max-w-3xl">
      <p
        class="font-body text-ink/50 text-center text-xs font-bold tracking-wide uppercase"
      >
        Lo que dicen mis pacientes
      </p>
      <div class="mt-5 grid gap-6 sm:grid-cols-2">
        {
          testimoniosDestacados.map((t) => (
            <figure class="ring-ink/5 rounded-2xl bg-white/70 p-6 shadow-sm ring-1">
              <blockquote class="font-body text-ink/80 text-sm italic">
                “{t.comentario}”
              </blockquote>
              <figcaption class="font-heading text-ink mt-4 flex items-center gap-3 text-sm font-semibold">
                <img
                  src={t.avatar}
                  alt={`Foto de ${t.nombre}`}
                  width="40"
                  height="40"
                  loading="lazy"
                  class="h-10 w-10 rounded-full object-cover"
                />
                {t.nombre}
              </figcaption>
            </figure>
          ))
        }
      </div>
    </div>
  </Section>

  <Section
    tinted
    eyebrow="Dónde encontrarme"
    titulo="Mis consultorios"
    centrado
    class="relative overflow-hidden"
  >
    <CerebroIcon
      class="text-secondary pointer-events-none absolute -top-8 -left-8 -z-10 size-40 -rotate-12 opacity-[0.07] md:size-52"
    />
    <CorazonIcon
      class="text-love pointer-events-none absolute -right-10 -bottom-10 -z-10 size-40 rotate-12 opacity-[0.07] md:size-52"
    />

    <div class="mx-auto mt-10 grid max-w-4xl gap-8 md:grid-cols-2">
      {
        presenciales.map((u) => (
          <article class="ring-ink/5 flex flex-col overflow-hidden rounded-3xl bg-white/70 shadow-sm ring-1">
            <MapEmbed
              query={u.mapsQuery as string}
              titulo={`Mapa de ${u.lugar}`}
              rounded={false}
              class="h-56 w-full"
            />
            <div class="flex flex-1 flex-col gap-1.5 p-6">
              <p class="font-body text-primary text-xs font-bold tracking-wide uppercase">
                Consultorio
              </p>
              <h3 class="font-heading text-ink text-xl font-semibold">
                {u.lugar.split(",")[0]}
              </h3>
              <p class="font-body text-ink/70 mt-1 flex items-start gap-2 text-sm">
                <MapPinIcon class="text-primary mt-0.5 h-4 w-4 shrink-0" />
                <span>{u.direccion ?? "Dirección exacta próximamente"}</span>
              </p>
              {u.mapsUrl && (
                <Button
                  href={u.mapsUrl}
                  variant="outline"
                  target="_blank"
                  class="mt-3 w-fit px-5 py-2 text-sm"
                >
                  Cómo llegar
                </Button>
              )}
            </div>
          </article>
        ))
      }
    </div>

    {
      enLinea && (
        <div class="from-love/10 to-accent/10 ring-ink/5 mx-auto mt-8 flex max-w-4xl flex-col items-center gap-4 rounded-3xl bg-gradient-to-br p-8 text-center shadow-sm ring-1 sm:flex-row sm:text-left">
          <span class="bg-love/10 text-love flex h-14 w-14 shrink-0 items-center justify-center rounded-full">
            <MapPinIcon class="h-7 w-7" />
          </span>
          <div>
            <h3 class="font-heading text-ink text-lg font-semibold">
              {enLinea.lugar}
            </h3>
            <p class="font-body text-ink/70 mt-1 text-sm">
              Consultas por videollamada — agenda por WhatsApp y te comparto los
              detalles.
            </p>
          </div>
        </div>
      )
    }
  </Section>
</Layout>
