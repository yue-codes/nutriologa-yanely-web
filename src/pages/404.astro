---
import Layout from "@layouts/Layout.astro";
import Button from "@components/ui/Button.astro";
---

<Layout
  title="Página no encontrada | Nutrióloga Yanely García"
  description="La página que buscas no existe o fue movida."
>
  <section class="px-4 py-20 text-center">
    <img
      src="/avatarnutri/nutry1.png"
      alt="Ilustración de una nutrióloga saltando alegremente"
      class="mx-auto h-64 w-auto"
    />
    <p class="font-body text-accent text-sm font-bold tracking-wide uppercase">
      Error 404
    </p>
    <h1 class="font-heading text-ink mt-2 text-4xl font-semibold md:text-5xl">
      No encontramos esta página
    </h1>
    <p class="font-body text-ink/80 mx-auto mt-4 max-w-xl">
      Puede que el enlace esté roto o que la página haya cambiado de lugar.
      Volvamos a un sitio conocido.
    </p>
    <div class="mt-8">
      <Button href="/">Volver al inicio</Button>
    </div>
  </section>
</Layout>
