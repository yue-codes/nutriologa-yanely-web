---
import Layout from "@layouts/Layout.astro";
import PageHeader from "@components/ui/PageHeader.astro";
import Button from "@components/ui/Button.astro";
import { getCollection, render } from "astro:content";
import { linkWhatsApp } from "@data/contacto";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const fechaFormateada = post.data.fecha.toLocaleDateString("es-MX", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
---

<Layout
  title={`${post.data.titulo} | Blog Nutrióloga Yanely García`}
  description={post.data.resumen}
>
  <PageHeader eyebrow={post.data.categoria} titulo={post.data.titulo} />

  <article class="mx-auto max-w-3xl px-4 py-16">
    <img
      src={post.data.imagen}
      alt={post.data.imagenAlt}
      width="800"
      height="500"
      class="w-full rounded-3xl object-cover"
    />
    <p class="font-body text-ink/60 mt-4 text-sm">{fechaFormateada}</p>
    <div class="blog-content font-body text-ink/90 mt-6">
      <Content />
    </div>
    {
      post.data.ctaTexto && post.data.ctaWhatsappMensaje && (
        <Button
          href={linkWhatsApp(post.data.ctaWhatsappMensaje)}
          variant="accent"
          target="_blank"
          class="mt-8"
        >
          {post.data.ctaTexto}
        </Button>
      )
    }
    <a
      href="/blog"
      class="font-body text-primary mt-10 inline-block font-semibold hover:underline"
    >
      ← Volver al blog
    </a>
  </article>
</Layout>
