---
/**
 * Ícono decorativo "hoja" — uno de los 4 símbolos del logo.
 * Dibujo simplificado propio, reemplazable cuando llegue el logo final.
 */
interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
>
  <path d="M6 14c0-5.2 4.2-9.5 12-9.5 0 8.4-4.2 12.5-9.5 12.5C6.7 17 6 15.7 6 14z" />
  <path d="M9 18c1-3.3 3.2-6.6 8-8.8" />
</svg>
