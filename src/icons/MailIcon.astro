---
interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.6"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
>
  <rect x="3" y="5" width="18" height="14" rx="2" />
  <path d="m3.5 6.5 8.5 6 8.5-6" />
</svg>
