---
/**
 * Ícono decorativo "mazorca de maíz" — uno de los 4 símbolos del logo.
 * Dibujo simplificado propio, reemplazable cuando llegue el logo final.
 */
interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
>
  <path d="M12 2c2.5 1 4 5.2 4 10s-1.5 9-4 10c-2.5-1-4-5.2-4-10S9.5 3 12 2z" />
  <path d="M9 6.5h6M8.4 9.5h7.2M8.2 12.5h7.6M8.4 15.5h7.2" />
  <path d="M9.3 19c-1.5 1-3 1-4-.2M14.7 19c1.5 1 3 1 4-.2" />
</svg>
